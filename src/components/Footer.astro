---
import { getCollection } from 'astro:content';
import { nav } from '../config/nav';

// Resolve which slugs have a real content file so we never link to a 404.
const docs = await getCollection('docs', ({ data }) => data.draft !== true);
const existing = new Set(docs.map((d) => d.id));

// Explore column: main sections → their first page.
const exploreLabels = ['Foundations', 'Context', 'Projects', 'PE Playbooks', 'Power Features', 'Best Practices'];
const explore = nav
  .filter((s) => exploreLabels.includes(s.label))
  .map((s) => ({ title: s.label, slug: s.items[0]?.slug ?? '' }));

// Resources column: the most-used shortcuts.
const resources = [
  { title: 'Prompt Library', slug: 'resources/prompt-library' },
  { title: 'Glossary', slug: 'resources/glossary' },
  { title: 'Cheat Sheet', slug: 'best-practices/cheat-sheet' },
  { title: 'Confidentiality', slug: 'best-practices/confidentiality' },
];

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-inner">
    <div class="footer-brand">
      <p class="footer-title">Claude for Private Equity</p>
      <p class="footer-tagline">Internal enablement: from the basics to confident daily use.</p>
    </div>

    <nav class="footer-col" aria-label="Explore">
      <p class="footer-heading">Explore</p>
      <ul>
        {
          explore.map((item) =>
            existing.has(item.slug) ? (
              <li><a href={`/${item.slug}`}>{item.title}</a></li>
            ) : (
              <li><span class="footer-soon">{item.title}<em>soon</em></span></li>
            )
          )
        }
      </ul>
    </nav>

    <nav class="footer-col" aria-label="Resources">
      <p class="footer-heading">Resources</p>
      <ul>
        {
          resources.map((item) =>
            existing.has(item.slug) ? (
              <li><a href={`/${item.slug}`}>{item.title}</a></li>
            ) : (
              <li><span class="footer-soon">{item.title}<em>soon</em></span></li>
            )
          )
        }
      </ul>
    </nav>
  </div>

  <div class="footer-bar">
    <div class="container footer-bar-inner">
      <span>© {year} · Claude for Private Equity</span>
      <span class="footer-confidential">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <rect x="5" y="11" width="14" height="9" rx="2" stroke="currentColor" stroke-width="2" />
          <path d="M8 11V8a4 4 0 0 1 8 0v3" stroke="currentColor" stroke-width="2" />
        </svg>
        Confidential · For internal KPMG use only, not for distribution
      </span>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: var(--space-24);
    border-top: 1px solid var(--line);
    background: var(--bg-soft);
  }
  .footer-inner {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1fr;
    gap: var(--space-12);
    padding-top: var(--space-16);
    padding-bottom: var(--space-12);
  }

  .footer-title {
    margin: 0;
    font-weight: 700;
    color: var(--ink);
  }
  .footer-tagline {
    margin: 2px 0 0;
    font-size: 0.9rem;
    color: var(--ink-muted);
    max-width: 30ch;
    line-height: 1.5;
  }

  .footer-heading {
    margin: 0 0 var(--space-3);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-muted);
  }
  .footer-col ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .footer-col a {
    color: var(--ink);
    font-size: 0.92rem;
    transition: color 0.15s ease;
  }
  .footer-col a:hover {
    color: var(--kpmg-blue);
    text-decoration: none;
  }
  .footer-soon {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: #9aa6b6;
    font-size: 0.92rem;
    cursor: default;
  }
  .footer-soon em {
    font-style: normal;
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #aeb8c6;
    background: var(--bg);
    border: 1px solid var(--line);
    border-radius: 4px;
    padding: 1px 5px;
  }

  .footer-bar {
    border-top: 1px solid var(--line);
  }
  .footer-bar-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-4);
    padding-top: var(--space-4);
    padding-bottom: var(--space-4);
    font-size: 0.84rem;
    color: var(--ink-muted);
  }
  .footer-bar-muted {
    color: #9aa6b6;
  }
  .footer-confidential {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.04em;
    color: #9a3030;
  }

  @media (max-width: 760px) {
    .footer-inner {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-8);
    }
    .footer-brand {
      grid-column: 1 / -1;
    }
    .footer-bar-inner {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-1);
    }
  }
</style>
