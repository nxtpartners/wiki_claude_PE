---
import { withBase } from '../utils/withBase';
interface Props {
  title: string;
  href?: string;
  eyebrow?: string;
  icon?: string;
}
const { title, href, eyebrow, icon } = Astro.props;
const Tag = href ? 'a' : 'div';
---

<Tag class:list={['card', { 'card-link': href }]} href={href ? withBase(href) : undefined} data-reveal>
  {
    icon && (
      <span class="card-icon" aria-hidden="true">
        {icon}
      </span>
    )
  }
  {eyebrow && <span class="card-eyebrow">{eyebrow}</span>}
  <h3 class="card-title">{title}</h3>
  <p class="card-desc"><slot /></p>
  {href && <span class="card-arrow" aria-hidden="true">→</span>}
</Tag>

<style>
  .card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding: var(--space-6);
    background: var(--bg);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    color: var(--ink);
    box-shadow: var(--shadow-xs);
    height: 100%;
  }
  .card-link {
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease,
      border-color 0.2s ease;
  }
  .card-link:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-md);
    border-color: color-mix(in srgb, var(--kpmg-cobalt) 40%, var(--line));
    text-decoration: none;
  }
  .card-icon {
    font-size: 1.5rem;
    line-height: 1;
    margin-bottom: var(--space-1);
  }
  .card-eyebrow {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--kpmg-cobalt);
  }
  .card-title {
    margin: 0;
    font-size: 1.12rem;
    font-weight: 700;
    letter-spacing: -0.01em;
  }
  .card-desc {
    margin: 0;
    color: var(--ink-muted);
    font-size: 0.95rem;
    line-height: 1.6;
  }
  .card-arrow {
    margin-top: auto;
    padding-top: var(--space-3);
    color: var(--kpmg-cobalt);
    font-weight: 700;
    transition: transform 0.2s ease;
  }
  .card-link:hover .card-arrow {
    transform: translateX(4px);
  }
</style>
