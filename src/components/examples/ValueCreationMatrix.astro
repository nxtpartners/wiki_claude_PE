---
// Example 1: AI Value Creation Matrix.
// A self-contained, re-skinned adaptation of a standalone KPMG deliverable:
// 19 AI value-creation use cases across five PE value levers, filterable by
// phase, fund tier, and KPMG service line.
//
// Design rules followed here:
//  - Never hardcode colors. Every hue is a wiki design token (--kpmg-blue,
//    --kpmg-cobalt, --kpmg-teal, --warning, --confidential, --ink-muted).
//    Badge tints are derived from those tokens with color-mix, so the whole
//    matrix stays on-palette with the rest of the wiki.
//  - No external fonts: Inter for body, JetBrains Mono (--font-mono) for the
//    micro-labels and badges.
//  - No em/en dashes anywhere. Ranges use a hyphen ("4-6 wks"); prose dashes
//    are rewritten as commas or colons.
//  - Mobile-adaptable: the wide table collapses to stacked cards under 720px
//    using data-label attributes; the .table-wrap keeps overflow-x for the
//    in-between range. No animation is added, so reduced-motion is respected.

const serviceLabels: Record<string, string> = {
  strategy: 'Strategy & Advisory',
  platform: 'Platform Build',
  impl: 'Implementation',
  managed: 'Managed Service',
  vc: 'Portfolio VC',
};

const phaseMeta: Record<string, { label: string; cls: string }> = {
  '100-Day': { label: '100-Day', cls: 'phase-100' },
  'Mid-Hold': { label: 'Mid-Hold', cls: 'phase-mid' },
  'Exit Prep': { label: 'Exit Prep', cls: 'phase-exit' },
  'All Phases': { label: 'Continuous', cls: 'phase-all' },
};
const tierMeta: Record<string, string> = {
  'Mid-Market': 'tier-mm',
  'Large-Cap': 'tier-lc',
  Both: 'tier-both',
};
const fitMeta: Record<string, string> = { High: 'pp-high', Medium: 'pp-med', Low: 'pp-low' };
const cxMeta: Record<string, string> = { Low: 'cx-low', Medium: 'cx-med', High: 'cx-high' };
const entryMeta: Record<string, string> = { build: 'entry-build', buy: 'entry-buy', partner: 'entry-partner' };

interface Row {
  sublever: string;
  usecase: string;
  phase: string;
  tier: string;
  filterServices: string;
  services: string[];
  airole: string;
  anchor: string;
  fit: string;
  complexity: string;
  ttv: string;
  duration: string;
  deps: string;
  entry: { type: string; label: string };
}
interface Lever {
  key: string;
  title: string;
  rows: Row[];
}

