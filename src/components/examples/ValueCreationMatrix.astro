<script>
  // Vanilla-JS multi-select filtering, scoped per matrix instance. Mirrors the
  // island pattern used by PromptCard.astro (no framework, no shared globals).
  document.querySelectorAll<HTMLElement>('[data-vcm]').forEach((root) => {
    const state: Record<string, Set<string>> = {
      phase: new Set(),
      tier: new Set(),
      service: new Set(),
    };

    const rows = Array.from(root.querySelectorAll<HTMLElement>('[data-row]'));
    const sections = Array.from(root.querySelectorAll<HTMLElement>('[data-lever-section]'));
    const countEl = root.querySelector<HTMLElement>('[data-count]');
    const leverCounts = Array.from(root.querySelectorAll<HTMLElement>('[data-lever-count]'));
    const buttons = Array.from(root.querySelectorAll<HTMLButtonElement>('[data-filter]'));

    const label = (n: number) => n + ' use case' + (n !== 1 ? 's' : '');

    function apply() {
      const per: Record<string, number> = {};
      let total = 0;

      rows.forEach((row) => {
        const p = row.dataset.phase || '';
        const t = row.dataset.tier || '';
        const s = (row.dataset.services || '').split(' ');

        const pm = state.phase.size === 0 || state.phase.has(p);
        const tm = state.tier.size === 0 || state.tier.has(t);
        const sm = state.service.size === 0 || s.some((v) => state.service.has(v));

        const show = pm && tm && sm;
        row.classList.toggle('is-hidden', !show);
        if (show) {
          total++;
          const lv = row.dataset.lever || '';
          per[lv] = (per[lv] || 0) + 1;
        }
      });

      leverCounts.forEach((el) => {
        const lv = el.dataset.leverCount || '';
        el.textContent = label(per[lv] || 0);
      });
      sections.forEach((sec) => {
        const lv = sec.dataset.leverSection || '';
        sec.classList.toggle('is-hidden', !per[lv]);
      });
      if (countEl) countEl.textContent = label(total);
    }

    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const group = btn.dataset.group || '';
        const value = btn.dataset.filter || '';
        const set = state[group];
        if (!set) return;

        if (value === '__all') {
          set.clear();
        } else if (set.has(value)) {
          set.delete(value);
        } else {
          set.add(value);
        }

        // Reflect state on the button row: "All" is active only when the group is empty.
        root.querySelectorAll<HTMLButtonElement>(`[data-group="${group}"]`).forEach((b) => {
          const v = b.dataset.filter || '';
          if (v === '__all') b.classList.toggle('active', set.size === 0);
          else b.classList.toggle('active', set.has(v));
        });

        apply();
      });
    });

    apply();
  });
</script>
