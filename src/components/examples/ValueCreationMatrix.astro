  'Complexity',
  'Time to Value \u2461',
  'Project Duration \u2461',
  'Key Dependencies',
  'Entry Point',
  'KPMG Services',
];
---

<section class="vcm" data-vcm aria-label="AI value creation matrix">
  <!-- Controls -->
  <div class="vcm-controls">
    <div class="vcm-group">
      <span class="vcm-group-label">Phase</span>
      <button type="button" class="vcm-filter active" data-group="phase" data-filter="__all">All</button>
      <button type="button" class="vcm-filter" data-group="phase" data-filter="100-Day">100-Day</button>
      <button type="button" class="vcm-filter" data-group="phase" data-filter="Mid-Hold">Mid-Hold</button>
      <button type="button" class="vcm-filter" data-group="phase" data-filter="Exit Prep">Exit Prep</button>
      <button type="button" class="vcm-filter" data-group="phase" data-filter="All Phases">Continuous</button>
    </div>
    <div class="vcm-group">
      <span class="vcm-group-label">Tier</span>
      <button type="button" class="vcm-filter active" data-group="tier" data-filter="__all">All</button>
      <button type="button" class="vcm-filter" data-group="tier" data-filter="Mid-Market">Mid-Market</button>
      <button type="button" class="vcm-filter" data-group="tier" data-filter="Large-Cap">Large-Cap</button>
      <button type="button" class="vcm-filter" data-group="tier" data-filter="Both">Both</button>
    </div>
    <div class="vcm-group">
      <span class="vcm-group-label">Service</span>
      <button type="button" class="vcm-filter active" data-group="service" data-filter="__all">All</button>
      <button type="button" class="vcm-filter" data-group="service" data-filter="strategy">Strategy & Advisory</button>
      <button type="button" class="vcm-filter" data-group="service" data-filter="platform">Platform Build</button>
      <button type="button" class="vcm-filter" data-group="service" data-filter="impl">Implementation</button>
      <button type="button" class="vcm-filter" data-group="service" data-filter="managed">Managed Service</button>
      <button type="button" class="vcm-filter" data-group="service" data-filter="vc">Portfolio VC</button>
    </div>
    <span class="vcm-count" data-count>{totalUseCases} use cases</span>
  </div>

  <!-- Lever sections -->
  {
    levers.map((lever) => (
      <div class="vcm-lever" data-lever-section={lever.key}>
        <div class="vcm-lever-head">
          <span class:list={['vcm-dot', `dot-${lever.key}`]} aria-hidden="true" />
          <h3 class="vcm-lever-title">{lever.title}</h3>
          <span class="vcm-lever-count" data-lever-count={lever.key} />
        </div>
        <div class="table-wrap">
          <table class="vcm-table">
            <thead>
              <tr>{columns.map((c) => <th>{c}</th>)}</tr>
            </thead>
            <tbody>
              {lever.rows.map((r) => (
                <tr
                  data-row
                  data-lever={lever.key}
                  data-phase={r.phase}
                  data-tier={r.tier}
                  data-services={r.filterServices}
                >
                  <td class="td-sublever" data-label="Sub-Lever">{r.sublever}</td>
