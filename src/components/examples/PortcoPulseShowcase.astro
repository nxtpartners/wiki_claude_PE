      gap: var(--space-3);
      padding: var(--space-4);
    }
    .pp-track-cell {
      grid-template-columns: 1fr auto;
      display: grid;
      align-items: center;
      width: 100%;
    }
    .pp-track-doclabel {
      display: inline-block;
      justify-self: start;
    }
