</style>

<script>
  // Vanilla-JS section switcher, scoped to the single PortCo Pulse instance.
  // Clicking a rail button activates that button and shows its matching view.
  // Mirrors the dependency-free island pattern used by ValueCreationMatrix.astro.
  const root = document.querySelector<HTMLElement>('[data-portco]');
  if (root) {
    const buttons = Array.from(root.querySelectorAll<HTMLButtonElement>('.pp-rail-btn'));
    const views = Array.from(root.querySelectorAll<HTMLElement>('.pp-view'));

    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const view = btn.dataset.view || '';

        buttons.forEach((b) => {
          const isActive = b === btn;
          b.classList.toggle('active', isActive);
          if (isActive) b.setAttribute('aria-current', 'page');
          else b.removeAttribute('aria-current');
        });

        views.forEach((v) => {
          v.classList.toggle('active', v.dataset.view === view);
        });
      });
    });
  }
</script>
