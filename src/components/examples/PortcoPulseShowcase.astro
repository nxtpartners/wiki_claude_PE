---
// Example 2: PortCo Pulse Dashboard.
// A self-contained, static re-skin of a fictional private equity portfolio
// monitoring platform (Meridian Capital Partners). Firm users watch a portfolio
// of companies submit monthly KPIs against an annual plan; the app surfaces the
// companies that are off track using a RAG status (green within 5% of plan,
// amber 5-15%, red over 15%). Operators submit KPIs by chatting with an AI
// assistant rather than filling forms.
//
// Design rules followed here:
//  - Never hardcode colors. Every hue is a wiki design token. The app's status
//    colors map to tokens: On Track -> var(--kpmg-teal); At Risk -> var(--warning);
//    Off Track -> var(--confidential). Chrome/headers -> var(--kpmg-blue);
//    accents -> var(--kpmg-cobalt). Tints are derived with color-mix.
//  - No external fonts: Inter for body, JetBrains Mono (--font-mono) for the
//    micro-labels, badges, and numeric readouts.
//  - No em/en dashes anywhere. Ranges use a hyphen; prose dashes are rewritten.
//  - Mobile-adaptable: the left icon rail becomes a horizontal tab bar under
//    720px (nav still works), the KPI table collapses to stacked cards using
//    data-label attributes, and multi-column layouts fall back to a single
//    column.
//  - Static showcase: no JS at all, so reduced-motion is respected by default.

const period = 'August 2026';
const fiscalYear = 'FY2026';

interface Company {
  name: string;
  sector: string;
  fund: string;
  revenue: string;
  bar: number; // percent of the portfolio max (Brighton $7.35M = 100%)
  status: 'ontrack' | 'atrisk' | 'offtrack';
}

// Portfolio companies, latest-period revenue. Bars are proportional to the
// max revenue in the set (Brighton Healthcare, $7.35M).
const companies: Company[] = [
  { name: 'Apex Industrial', sector: 'Industrial', fund: 'Fund I', revenue: '$2.87M', bar: 39, status: 'ontrack' },
  { name: 'Brighton Healthcare', sector: 'Healthcare', fund: 'Fund I', revenue: '$7.35M', bar: 100, status: 'ontrack' },
  { name: 'Keystone Logistics', sector: 'Logistics', fund: 'Fund II', revenue: '$4.05M', bar: 55, status: 'atrisk' },
  { name: 'Veridian Software', sector: 'SaaS', fund: 'Fund II', revenue: '$1.21M', bar: 16, status: 'ontrack' },
  { name: 'Evergreen Fitness', sector: 'Fitness', fund: 'Fund III', revenue: '$548K', bar: 7, status: 'offtrack' },
  { name: 'OptiFi Solutions', sector: 'FinTech', fund: 'Fund III', revenue: '$1.61M', bar: 22, status: 'ontrack' },
  { name: 'StreamVibe Media', sector: 'Media', fund: 'Fund III', revenue: '$962K', bar: 13, status: 'ontrack' },
  { name: 'Culinary Concepts', sector: 'Restaurant', fund: 'Fund III', revenue: '$528K', bar: 7, status: 'ontrack' },
];

const stats = [
  { key: 'companies', label: 'Total Companies', value: '8' },
  { key: 'pending', label: 'Pending Submissions', value: '2' },
  { key: 'alerts', label: 'Alerts', value: '2' },
];

interface KpiRow {
  kpi: string;
  actual: string;
  plan: string;
  variance: string;
  status: 'ontrack' | 'atrisk' | 'offtrack';
  statusLabel: string;
}

// Company analytics for Veridian Software.
const kpiRows: KpiRow[] = [
  { kpi: 'Revenue', actual: '$1.21M', plan: '$1.19M', variance: '+1.3%', status: 'ontrack', statusLabel: 'On Track' },
  { kpi: 'EBITDA', actual: '$285K', plan: '$310K', variance: '-8.1%', status: 'atrisk', statusLabel: 'At Risk' },
  { kpi: 'Gross Margin', actual: '72.1%', plan: '71.5%', variance: '+0.8%', status: 'ontrack', statusLabel: 'On Track' },
  { kpi: 'Headcount', actual: '52', plan: '50', variance: '+4%', status: 'ontrack', statusLabel: 'On Track' },
  { kpi: 'NPS', actual: '61', plan: '58', variance: '+5.2%', status: 'ontrack', statusLabel: 'On Track' },
];

type DocState = 'in' | 'out' | 'na';
interface TrackingRow {
  name: string;
  docs: DocState[]; // KPI, BS, IS, CF
}

// Submission tracking: doc status per company. in = submitted, out = missing,
// na = not required.
const trackingRows: TrackingRow[] = [
  { name: 'Apex Industrial', docs: ['in', 'in', 'in', 'in'] },
  { name: 'Brighton Healthcare', docs: ['in', 'in', 'in', 'in'] },
  { name: 'Keystone Logistics', docs: ['in', 'in', 'in', 'out'] },
  { name: 'Veridian Software', docs: ['in', 'in', 'in', 'na'] },
  { name: 'Evergreen Fitness', docs: ['in', 'out', 'out', 'out'] },
  { name: 'OptiFi Solutions', docs: ['in', 'in', 'in', 'in'] },
];
const docLabels = ['KPI', 'BS', 'IS', 'CF'];
---

<section class="pp" data-portco aria-label="PortCo Pulse portfolio dashboard">
  <div class="pp-shell">
    <!-- Slim left icon rail -->
    <nav class="pp-rail" aria-label="PortCo Pulse sections">
      <span class="pp-rail-mark" aria-hidden="true">P</span>
      <button type="button" class="pp-rail-btn active" data-view="dashboard" aria-label="Dashboard" aria-current="page">
        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" aria-hidden="true">
          <rect x="3" y="3" width="7" height="9" rx="1.5" stroke="currentColor" stroke-width="1.7" />
          <rect x="14" y="3" width="7" height="5" rx="1.5" stroke="currentColor" stroke-width="1.7" />
          <rect x="14" y="12" width="7" height="9" rx="1.5" stroke="currentColor" stroke-width="1.7" />
          <rect x="3" y="16" width="7" height="5" rx="1.5" stroke="currentColor" stroke-width="1.7" />
        </svg>
      </button>
      <button type="button" class="pp-rail-btn" data-view="tracking" aria-label="Tracking">
        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" aria-hidden="true">
          <path d="M4 19V5m0 14h16M8 15l3-4 3 2 4-6" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </button>
      <button type="button" class="pp-rail-btn" data-view="data" aria-label="Data">
        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" aria-hidden="true">
          <ellipse cx="12" cy="6" rx="7" ry="3" stroke="currentColor" stroke-width="1.7" />
          <path d="M5 6v6c0 1.7 3.1 3 7 3s7-1.3 7-3V6M5 12v6c0 1.7 3.1 3 7 3s7-1.3 7-3v-6" stroke="currentColor" stroke-width="1.7" />
        </svg>
      </button>
      <button type="button" class="pp-rail-btn" data-view="settings" aria-label="Settings">
        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" aria-hidden="true">
          <circle cx="12" cy="12" r="3" stroke="currentColor" stroke-width="1.7" />
          <path d="M12 2v3m0 14v3M4.2 4.2l2.1 2.1m11.4 11.4 2.1 2.1M2 12h3m14 0h3M4.2 19.8l2.1-2.1m11.4-11.4 2.1-2.1" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" />
        </svg>
      </button>
    </nav>

    <!-- Main app column -->
    <div class="pp-main">
      <!-- Topbar -->
      <div class="pp-topbar">
        <div class="pp-wordmark">
          <span class="pp-brand">PortCo Pulse</span>
          <span class="pp-firm">Meridian Capital Partners</span>
        </div>
        <div class="pp-period">
          <span class="pp-period-label">Period</span>
          <span class="pp-period-value">{period}</span>
        </div>
      </div>

      <div class="pp-content">
        <!-- Dashboard view -->
        <div class="pp-view active" data-view="dashboard">
        <!-- Dashboard header -->
        <div class="pp-head">
          <div>
            <p class="pp-eyebrow">Portfolio Dashboard</p>
            <h3 class="pp-title">Portfolio Overview</h3>
          </div>
          <span class="pp-fy">{fiscalYear} plan</span>
        </div>

        <!-- Stat cards -->
        <div class="pp-stats">
          {
            stats.map((s) => (
              <div class:list={['pp-stat', `stat-${s.key}`]}>
                <span class="pp-stat-chip" aria-hidden="true">
                  {s.key === 'companies' && (
                    <svg viewBox="0 0 24 24" width="18" height="18" fill="none">
                      <rect x="3" y="8" width="8" height="12" rx="1.5" stroke="currentColor" stroke-width="1.7" />
                      <rect x="13" y="4" width="8" height="16" rx="1.5" stroke="currentColor" stroke-width="1.7" />
                      <path d="M6 12h2m-2 3h2m9-7h2m-2 4h2m-2 4h2" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" />
                    </svg>
                  )}
                  {s.key === 'pending' && (
                    <svg viewBox="0 0 24 24" width="18" height="18" fill="none">
                      <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.7" />
                      <path d="M12 7v5l3 2" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                  )}
                  {s.key === 'alerts' && (
                    <svg viewBox="0 0 24 24" width="18" height="18" fill="none">
                      <path d="M12 3 2.5 20h19L12 3Z" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round" />
                      <path d="M12 9v5m0 3h.01" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" />
                    </svg>
                  )}
                </span>
                <span class="pp-stat-value">{s.value}</span>
                <span class="pp-stat-label">{s.label}</span>
              </div>
            ))
          }
        </div>

        <!-- Portfolio performance bar chart -->
        <div class="pp-panel">
          <div class="pp-panel-head">
            <h4 class="pp-panel-title">Portfolio Performance</h4>
            <span class="pp-panel-note">Latest-period revenue</span>
          </div>
          <div class="pp-chart">
            {
              companies.map((c) => (
                <div class:list={['pp-bar-row', `bar-${c.status}`]}>
                  <span class="pp-bar-name">{c.name}</span>
                  <span class="pp-bar-track" aria-hidden="true">
                    <span class="pp-bar-fill" style={`width:${c.bar}%`} />
                  </span>
                  <span class="pp-bar-value">{c.revenue}</span>
                </div>
              ))
            }
          </div>
        </div>

        <!-- Off Track / At Risk -->
        <div class="pp-alerts">
          <div class="pp-alert alert-offtrack">
            <div class="pp-alert-head">
              <span class="pp-alert-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none">
                  <path d="M12 3 2.5 20h19L12 3Z" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round" />
                  <path d="M12 9v5m0 3h.01" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" />
                </svg>
              </span>
              <span class="pp-alert-tag">Off Track</span>
            </div>
            <p class="pp-alert-co">Evergreen Fitness</p>
            <p class="pp-alert-note">Revenue 20% below plan: $548K vs $650K</p>
          </div>

          <div class="pp-alert alert-atrisk">
            <div class="pp-alert-head">
              <span class="pp-alert-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none">
                  <path d="M12 3 2.5 20h19L12 3Z" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round" />
                  <path d="M12 9v5m0 3h.01" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" />
                </svg>
              </span>
              <span class="pp-alert-tag">At Risk</span>
            </div>
            <p class="pp-alert-co">Keystone Logistics</p>
            <p class="pp-alert-note">EBITDA margin at risk: 12.5% variance</p>
          </div>
        </div>
        </div>
        <!-- End dashboard view -->

        <!-- Data view -->
        <div class="pp-view" data-view="data">
        <!-- Data header -->
        <div class="pp-head">
          <div>
            <p class="pp-eyebrow">Company Analytics</p>
            <h3 class="pp-title">Veridian Software</h3>
          </div>
          <span class="pp-fy">{fiscalYear} plan</span>
        </div>

        <!-- Company analytics KPI table -->
        <div class="pp-panel">
          <div class="pp-panel-head">
            <h4 class="pp-panel-title">Company Analytics</h4>
            <span class="pp-panel-note">Veridian Software</span>
          </div>
          <div class="pp-table-wrap">
            <table class="pp-table">
              <thead>
                <tr>
                  <th>KPI</th>
                  <th>Actual</th>
                  <th>Plan</th>
                  <th>Var %</th>
                  <th>Status</th>
                </tr>
              </thead>
              <tbody>
                {
                  kpiRows.map((r) => (
                    <tr>
                      <td class="pp-td-kpi" data-label="KPI">{r.kpi}</td>
                      <td class="pp-td-num" data-label="Actual">{r.actual}</td>
                      <td class="pp-td-num" data-label="Plan">{r.plan}</td>
                      <td class="pp-td-num" data-label="Var %">{r.variance}</td>
                      <td data-label="Status">
                        <span class:list={['pp-badge', `st-${r.status}`]}>{r.statusLabel}</span>
                      </td>
                    </tr>
                  ))
                }
              </tbody>
            </table>
          </div>
        </div>
        </div>
        <!-- End data view -->

        <!-- Tracking view -->
        <div class="pp-view" data-view="tracking">
        <!-- Tracking header -->
        <div class="pp-head">
          <div>
            <p class="pp-eyebrow">Submissions</p>
            <h3 class="pp-title">Submission Tracking</h3>
          </div>
          <span class="pp-fy">{fiscalYear} plan</span>
        </div>

        <!-- Submission tracking -->
        <div class="pp-panel">
          <div class="pp-panel-head">
            <h4 class="pp-panel-title">Submission Tracking</h4>
            <span class="pp-panel-note">{period}</span>
          </div>
          <div class="pp-track">
            <div class="pp-track-head" aria-hidden="true">
              <span class="pp-track-co">Company</span>
              {docLabels.map((d) => <span class="pp-track-doc">{d}</span>)}
            </div>
            {
              trackingRows.map((row) => (
                <div class="pp-track-row">
                  <span class="pp-track-co">{row.name}</span>
                  {row.docs.map((state, i) => (
                    <span class="pp-track-cell">
                      <span class="pp-track-doclabel" aria-hidden="true">{docLabels[i]}</span>
                      <span class:list={['pp-chip', `chip-${state}`]} aria-label={docLabels[i] + ' ' + (state === 'in' ? 'submitted' : state === 'out' ? 'missing' : 'not required')}>
                        {state === 'in' && (
                          <svg viewBox="0 0 24 24" width="13" height="13" fill="none" aria-hidden="true">
                            <path d="m5 12 4 4 10-10" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" />
                          </svg>
                        )}
                        {state === 'out' && (
                          <svg viewBox="0 0 24 24" width="13" height="13" fill="none" aria-hidden="true">
                            <path d="M6 6l12 12M18 6 6 18" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" />
                          </svg>
                        )}
                        {state === 'na' && (
                          <svg viewBox="0 0 24 24" width="13" height="13" fill="none" aria-hidden="true">
                            <path d="M6 12h12" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" />
                          </svg>
                        )}
                      </span>
                    </span>
                  ))}
                </div>
              ))
            }
          </div>
          <div class="pp-track-summary">
            <span class="pp-track-stat"><span class="dot dot-in" aria-hidden="true"></span>6 complete</span>
            <span class="pp-track-stat"><span class="dot dot-part" aria-hidden="true"></span>1 partial</span>
            <span class="pp-track-stat"><span class="dot dot-out" aria-hidden="true"></span>1 missing</span>
            <span class="pp-track-pct">86% complete</span>
          </div>
        </div>
        </div>
        <!-- End tracking view -->

        <!-- Settings view -->
        <div class="pp-view" data-view="settings">
          <!-- Settings header -->
          <div class="pp-head">
            <div>
              <p class="pp-eyebrow">Configuration</p>
              <h3 class="pp-title">Settings</h3>
            </div>
            <span class="pp-fy">{fiscalYear} plan</span>
          </div>

          <!-- RAG thresholds -->
          <div class="pp-panel">
            <div class="pp-panel-head">
              <h4 class="pp-panel-title">RAG Thresholds</h4>
              <span class="pp-panel-note">Status rules</span>
            </div>
            <div class="pp-setting-row">
              <span class="pp-setting-label">On Track: within 5% of plan</span>
              <span class="pp-badge st-ontrack">On Track</span>
            </div>
            <div class="pp-setting-row">
              <span class="pp-setting-label">At Risk: 5-15% below plan</span>
              <span class="pp-badge st-atrisk">At Risk</span>
            </div>
            <div class="pp-setting-row">
              <span class="pp-setting-label">Off Track: over 15% below plan</span>
              <span class="pp-badge st-offtrack">Off Track</span>
            </div>
          </div>

          <!-- Reporting -->
          <div class="pp-panel">
            <div class="pp-panel-head">
              <h4 class="pp-panel-title">Reporting</h4>
              <span class="pp-panel-note">Cadence</span>
            </div>
            <div class="pp-setting-row">
              <span class="pp-setting-label">Fiscal year</span>
              <span class="pp-setting-value">FY2026</span>
            </div>
            <div class="pp-setting-row">
              <span class="pp-setting-label">Reporting cadence</span>
              <span class="pp-setting-value">Monthly</span>
            </div>
          </div>
        </div>
        <!-- End settings view -->
      </div>
    </div>
  </div>
</section>

<style>
  /* Component-scoped token map: every hue derives from a wiki design token.
     App status colors map to tokens; tints are built with color-mix. */
  .pp {
    --st-ontrack: var(--kpmg-teal);
    --st-atrisk: var(--warning);
    --st-offtrack: var(--confidential);
    --chrome: var(--kpmg-blue);
    --accent: var(--kpmg-cobalt);

    font-family: var(--font-sans);
    color: var(--ink);
    font-size: 0.95rem;
    line-height: 1.6;
  }

  .pp-shell {
    display: flex;
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--bg);
    box-shadow: var(--shadow-sm);
  }

  /* ---- Left icon rail ---- */
  .pp-rail {
    flex: 0 0 72px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-4) 0;
    background: var(--chrome);
  }
  .pp-rail-mark {
    display: grid;
    place-items: center;
    width: 34px;
    height: 34px;
    border-radius: var(--radius-md);
    background: rgba(255, 255, 255, 0.14);
    color: #fff;
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 1rem;
    margin-bottom: var(--space-3);
  }
  .pp-rail-btn {
    display: grid;
    place-items: center;
    width: 40px;
    height: 40px;
    border: none;
    border-radius: var(--radius-md);
    background: transparent;
    color: rgba(255, 255, 255, 0.6);
    cursor: pointer;
  }
  .pp-rail-btn:hover {
    background: rgba(255, 255, 255, 0.1);
    color: #fff;
  }
  .pp-rail-btn.active {
    background: rgba(255, 255, 255, 0.16);
    color: #fff;
  }

  /* ---- Main column ---- */
  .pp-main {
    flex: 1 1 auto;
    min-width: 0;
    display: flex;
    flex-direction: column;
    background: var(--bg-soft);
    /* Hold the window at roughly the tallest (dashboard) view's height so
       switching to the shorter tracking, data, or settings views does not
       shrink the mockup. Shorter views stay top-aligned and simply leave
       whitespace at the bottom. Reset to auto on mobile below.
       Raised from 680px after the stat cards, chart panel, and alerts gained
       real padding (var(--space-6) = 24px top + bottom each, previously an
       undefined token that rendered as 0). The dashboard has three padded
       blocks stacked vertically (stat-card row, chart panel, alert row), so it
       grew by ~3 x 48px = 144px to ~824px; rounded up to 860px for headroom. */
    min-height: 860px;
  }

  /* ---- Topbar ---- */
  .pp-topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    padding: var(--space-4) var(--space-6);
    background: var(--bg);
    border-bottom: 1px solid var(--line);
  }
  .pp-wordmark {
    display: flex;
    align-items: baseline;
    gap: var(--space-3);
    flex-wrap: wrap;
  }
  .pp-brand {
    font-weight: 800;
    letter-spacing: -0.01em;
    color: var(--chrome);
    font-size: 1.02rem;
  }
  .pp-firm {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.04em;
    color: var(--ink-muted);
  }
  .pp-period {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    line-height: 1.2;
  }
  .pp-period-label {
    font-family: var(--font-mono);
    font-size: 0.58rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-muted);
  }
  .pp-period-value {
    font-weight: 650;
    font-size: 0.86rem;
    color: var(--ink);
  }

  /* ---- Content ---- */
  .pp-content {
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
  }

  /* ---- Switchable views ---- */
  .pp-view {
    display: none;
    flex-direction: column;
    gap: var(--space-6);
  }
  .pp-view.active {
    display: flex;
  }

  /* ---- Settings rows ---- */
  .pp-setting-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    padding: var(--space-3) 0;
    border-bottom: 1px solid var(--line);
  }
  .pp-setting-row:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }
  .pp-setting-label {
    font-size: 0.84rem;
    color: var(--ink);
  }
  .pp-setting-value {
    font-family: var(--font-mono);
    font-size: 0.76rem;
    color: var(--ink-muted);
  }

  .pp-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: var(--space-4);
    flex-wrap: wrap;
  }
  .pp-eyebrow {
    margin: 0 0 2px;
    font-family: var(--font-mono);
    font-size: 0.64rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
  }
  .pp-title {
    margin: 0;
    font-size: 1.2rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--ink);
  }
  .pp-fy {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.04em;
    color: var(--ink-muted);
    background: var(--bg);
    border: 1px solid var(--line);
