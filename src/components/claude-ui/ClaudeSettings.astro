---
// ClaudeSettings: a recreated claude.ai Settings panel for the standing
// "Instructions for Claude" field. Display-only, warm cream + clay, never
// KPMG blue. Used to show readers exactly where the feature is configured.
//
// Props:
//   - title: the field heading (default "Instructions for Claude")
//   - help:  a short descriptor line under the heading
//   - save:  the save button label (default "Save")
//
// Default slot: the instruction lines the user has typed into the field.

interface Props {
  title?: string;
  help?: string;
  save?: string;
}
const {
  title = 'Instructions for Claude',
  help = 'Claude keeps these in mind across all your chats.',
  save = 'Save',
} = Astro.props;
---

<div class="cs">
  <p class="cs-eyebrow">Settings, Profile</p>
  <h3 class="cs-title">{title}</h3>
  <p class="cs-help">{help}</p>

  <div class="cs-field">
    <div class="cs-field-body">
      <slot />
    </div>
    <span class="cs-caret" aria-hidden="true"></span>
  </div>

  <div class="cs-actions">
    <button type="button" class="cs-save" aria-hidden="true">{save}</button>
  </div>
</div>

<style>
  .cs {
    background: var(--c-bg);
    padding: var(--space-6);
    color: var(--c-text);
  }

  .cs-eyebrow {
    margin: 0 0 var(--space-3);
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--c-clay);
  }
  .cs-title {
    margin: 0 0 var(--space-2);
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--c-heading);
    letter-spacing: -0.01em;
  }
  .cs-help {
    margin: 0 0 var(--space-4);
    font-size: 0.84rem;
    color: var(--c-muted);
  }

  .cs-field {
    position: relative;
    background: var(--c-panel);
    border: 1px solid var(--c-border);
    border-radius: var(--radius-md);
    padding: var(--space-4) var(--space-5);
    min-height: 140px;
  }
  .cs-field-body {
    font-size: 0.88rem;
    line-height: 1.6;
    color: var(--c-text);
  }
  .cs-field-body :global(p) {
    margin: 0 0 var(--space-2);
  }
  .cs-field-body :global(p:last-child) {
    margin-bottom: 0;
  }
  .cs-caret {
    position: absolute;
    left: var(--space-5);
    bottom: var(--space-4);
    width: 1.5px;
    height: 1.05em;
    background: var(--c-clay);
  }

  .cs-actions {
    display: flex;
    justify-content: flex-end;
    margin-top: var(--space-4);
  }
  .cs-save {
    font-family: var(--font-sans);
    font-size: 0.82rem;
    font-weight: 600;
    line-height: 1;
    color: #fff;
    background: var(--c-clay);
    border: none;
    border-radius: 999px;
    padding: 0.7em 1.4em;
    cursor: default;
  }
</style>
