---
interface Props {
  eyebrow?: string;
  title: string;
  subtitle: string;
}
const { eyebrow, title, subtitle } = Astro.props;
---

<section class="hero">
  <div class="hero-bg" aria-hidden="true">
    <div class="hero-grid"></div>
    <div class="hero-glow"></div>
  </div>
  <div class="container hero-inner">
    {eyebrow && <p class="hero-eyebrow" data-hero="1">{eyebrow}</p>}
    <h1 class="hero-title" data-hero="2">{title}</h1>
    <p class="hero-subtitle" data-hero="3">{subtitle}</p>
    <div class="hero-actions" data-hero="4">
      <slot name="actions" />
    </div>
    <div class="hero-meta" data-hero="5">
      <slot name="meta" />
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    background: linear-gradient(180deg, #f7f9fc 0%, var(--bg) 100%);
    border-bottom: 1px solid var(--line);
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }
  .hero-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(to right, rgba(0, 51, 141, 0.04) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(0, 51, 141, 0.04) 1px, transparent 1px);
    background-size: 56px 56px;
    mask-image: radial-gradient(ellipse 80% 60% at 50% 0%, #000 30%, transparent 78%);
    -webkit-mask-image: radial-gradient(ellipse 80% 60% at 50% 0%, #000 30%, transparent 78%);
  }
  .hero-glow {
    position: absolute;
    top: -180px;
    left: 50%;
    transform: translateX(-50%);
    width: 760px;
    height: 520px;
    background: radial-gradient(
      circle at 50% 30%,
      rgba(30, 73, 226, 0.12),
      rgba(172, 234, 255, 0.08) 38%,
      transparent 68%
    );
    filter: blur(8px);
  }

  .hero-inner {
    position: relative;
    text-align: center;
    padding-top: var(--space-24);
    padding-bottom: var(--space-24);
    max-width: 880px;
  }
  .hero-eyebrow {
    margin: 0 0 var(--space-4);
    font-size: 0.82rem;
    font-weight: 650;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--kpmg-cobalt);
  }
  .hero-title {
    margin: 0 0 var(--space-6);
    font-size: clamp(2.6rem, 1.8rem + 3.4vw, 4.4rem);
    font-weight: 800;
    line-height: 1.04;
    letter-spacing: -0.035em;
    background: linear-gradient(180deg, var(--ink) 0%, #1c3563 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .hero-subtitle {
    margin: 0 auto var(--space-8);
    max-width: 640px;
    font-size: clamp(1.05rem, 1rem + 0.4vw, 1.28rem);
    line-height: 1.6;
    color: var(--ink-muted);
  }
  .hero-actions {
    display: flex;
    gap: var(--space-3);
    justify-content: center;
    flex-wrap: wrap;
  }
  .hero-meta {
    margin-top: var(--space-12);
  }

  @media (max-width: 600px) {
    .hero-inner {
      padding-top: var(--space-16);
      padding-bottom: var(--space-16);
    }
  }
</style>
