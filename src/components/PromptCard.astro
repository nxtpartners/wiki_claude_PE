---
// Signature component: a ready-to-use example prompt on the dark code surface,
// with a "Prompt" label and a working Copy button (vanilla JS island).
// Prompt text can be passed via the `prompt` prop OR the default slot.

interface Props {
  prompt?: string;
  label?: string;
  title?: string;
}
const { prompt, label = 'Prompt', title } = Astro.props;

const uid = 'pc-' + Math.random().toString(36).slice(2, 9);
---

<figure class="prompt-card" data-prompt-card>
  <figcaption class="pc-head">
    <span class="pc-label">
      <svg viewBox="0 0 24 24" width="13" height="13" fill="none" aria-hidden="true">
        <path d="m8 9 3 3-3 3M13 15h3" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
        <rect x="3" y="4" width="18" height="16" rx="2.5" stroke="currentColor" stroke-width="1.6" />
      </svg>
      {label}{title ? <span class="pc-title"> · {title}</span> : null}
    </span>
    <button type="button" class="pc-copy" data-copy-btn aria-label="Copy prompt to clipboard">
      <svg class="pc-copy-icon" viewBox="0 0 24 24" width="15" height="15" fill="none" aria-hidden="true">
        <rect x="9" y="9" width="11" height="11" rx="2" stroke="currentColor" stroke-width="1.7" />
        <path d="M5 15V5a2 2 0 0 1 2-2h8" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" />
      </svg>
      <span class="pc-copy-text">Copy</span>
    </button>
  </figcaption>
  <pre class="pc-body" id={uid} data-prompt-text>{prompt ? prompt : <slot />}</pre>
</figure>

<style>
  .prompt-card {
    margin: var(--space-6) 0;
    border-radius: var(--radius-md);
    overflow: hidden;
    border: 1px solid var(--bg-code);
    box-shadow: var(--shadow-sm);
  }
  .pc-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 10px var(--space-4);
    background: #122544;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }
  .pc-label {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--kpmg-sky);
  }
  .pc-title {
    color: rgba(255, 255, 255, 0.55);
    font-weight: 500;
    letter-spacing: 0.02em;
    text-transform: none;
  }

  .pc-copy {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 5px 11px;
    font-family: var(--font-sans);
    font-size: 0.78rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.82);
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.14);
    border-radius: var(--radius-sm);
    cursor: pointer;
    transition:
      background 0.16s ease,
      color 0.16s ease,
      transform 0.12s ease;
  }
  .pc-copy:hover {
    background: rgba(255, 255, 255, 0.16);
    color: #fff;
  }
  .pc-copy.copied {
    background: rgba(0, 163, 161, 0.22);
    border-color: rgba(0, 163, 161, 0.5);
    color: #d6fbfa;
  }

  .pc-body {
    margin: 0;
    padding: var(--space-6);
    background: var(--bg-code);
    color: #e7edf6;
    font-family: var(--font-mono);
    font-size: 0.84rem;
    line-height: 1.65;
    white-space: pre-wrap;
    word-break: break-word;
    border: none;
    border-radius: 0;
  }
</style>

<script>
  // Copy-button micro-interaction (no framework needed).
  document.querySelectorAll<HTMLElement>('[data-prompt-card]').forEach((card) => {
    const btn = card.querySelector<HTMLButtonElement>('[data-copy-btn]');
    const body = card.querySelector<HTMLElement>('[data-prompt-text]');
    const textEl = btn?.querySelector<HTMLElement>('.pc-copy-text');
    if (!btn || !body) return;

    btn.addEventListener('click', async () => {
      const text = (body.innerText || '').trim();
      try {
        await navigator.clipboard.writeText(text);
      } catch {
        // Fallback for older browsers / insecure contexts.
        const ta = document.createElement('textarea');
        ta.value = text;
        ta.style.position = 'fixed';
        ta.style.opacity = '0';
        document.body.appendChild(ta);
        ta.select();
        try {
          document.execCommand('copy');
        } catch {}
        ta.remove();
      }
      btn.classList.add('copied');
      if (textEl) textEl.textContent = 'Copied';
      window.setTimeout(() => {
        btn.classList.remove('copied');
        if (textEl) textEl.textContent = 'Copy';
      }, 1600);
    });
  });
</script>
