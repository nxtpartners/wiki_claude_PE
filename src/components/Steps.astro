---
// Wrapper for a numbered step-by-step sequence with a connecting vertical line.
// Use with <Step> children. The CSS counter on the wrapper numbers the badges.
---

<ol class="steps">
  <slot />
</ol>

<style>
  .steps {
    list-style: none;
    counter-reset: step;
    margin: var(--space-6) 0;
    padding: 0;
    position: relative;
  }
  /* connecting vertical line */
  .steps::before {
    content: '';
    position: absolute;
    left: 15px;
    top: 12px;
    bottom: 12px;
    width: 2px;
    background: var(--line);
  }
</style>
