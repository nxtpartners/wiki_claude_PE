---
interface Props {
  title?: string;
}
const { title } = Astro.props;
---

<li class="step">
  <span class="step-badge" aria-hidden="true"></span>
  <div class="step-body">
    {title && <p class="step-title">{title}</p>}
    <div class="step-content"><slot /></div>
  </div>
</li>

<style>
  .step {
    position: relative;
    display: flex;
    gap: var(--space-4);
    padding: 0 0 var(--space-6) 0;
    counter-increment: step;
  }
  .step:last-child {
    padding-bottom: 0;
  }
  .step-badge {
    position: relative;
    z-index: 1;
    flex: 0 0 32px;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: var(--kpmg-blue);
    color: #fff;
    display: grid;
    place-items: center;
    font-weight: 700;
    font-size: 0.92rem;
    box-shadow: 0 0 0 4px var(--bg);
  }
  .step-badge::before {
    content: counter(step);
  }
  .step-body {
    padding-top: 3px;
    flex: 1;
  }
  .step-title {
    margin: 0 0 var(--space-2);
    font-weight: 650;
    font-size: 1.05rem;
    color: var(--ink);
  }
  .step-content :global(p:last-child) {
    margin-bottom: 0;
  }
</style>
