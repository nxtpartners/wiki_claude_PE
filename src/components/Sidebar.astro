---
import { getCollection } from 'astro:content';
import type { NavSection, Track } from '../config/nav';
import { TRACKS } from '../config/nav';
import { withBase } from '../utils/withBase';

interface Props {
  currentSlug: string;
  sections: NavSection[];
  track: Track;
}
const { currentSlug, sections, track } = Astro.props;

// Resolve which slugs have a real content file so we never link to a 404.
const docs = await getCollection('docs', ({ data }) => data.draft !== true);
const existing = new Set(docs.map((d) => d.id));

// Position (1-based) for each slug WITHIN this track, so the sidebar number
// matches the "X of N" shown in each page's header.
const trackItems = sections.flatMap((s) => s.items);
const positionOf = new Map(trackItems.map((item, i) => [item.slug, i + 1]));
const pad = (n: number) => String(n).padStart(2, '0');

// The switcher points at the opposite track's landing page.
const otherTrack: Track = track === 'core' ? 'advanced' : 'core';
const current = TRACKS[track];
const other = TRACKS[otherTrack];
---

<nav class="sidebar" aria-label="Wiki navigation">
  <div class="sidebar-scroll">
    <div class="track-switcher">
      <a class="track-home" href={withBase('/')}>
        <svg viewBox="0 0 24 24" width="13" height="13" fill="none" aria-hidden="true">
          <path d="M4 11l8-7 8 7M6 9.5V20h12V9.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
        <span>Home</span>
      </a>
      <p class="track-eyebrow">{current.tagline}</p>
      <p class="track-name">{current.name}</p>
      <a class="track-switch" href={withBase('/' + other.homeSlug)}>
        <span>Switch to {other.name}</span>
        <svg viewBox="0 0 24 24" width="13" height="13" fill="none" aria-hidden="true">
          <path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </a>
    </div>
    {
      sections.map((section) => (
        <>
        <div class="nav-section">
          <p class="nav-label">{section.label}</p>
          <ul class="nav-list">
            {section.items.map((item) => {
              const isActive = item.slug === currentSlug;
              const exists = existing.has(item.slug);
              const num = positionOf.get(item.slug);
              return (
                <li>
                  {exists ? (
                    <a
                      href={withBase(item.slug)}
                      class:list={['nav-link', { active: isActive }]}
                      aria-current={isActive ? 'page' : undefined}
                    >
                      <span class="nav-num" aria-hidden="true">{num ? pad(num) : ''}</span>
                      <span class="nav-text">{item.title}</span>
                    </a>
                  ) : (
                    <span class="nav-link nav-soon" title="Coming soon">
                      <span class="nav-num" aria-hidden="true">{num ? pad(num) : ''}</span>
                      <span class="nav-text">{item.title}</span>
                      <span class="soon-tag">soon</span>
                    </span>
                  )}
                </li>
              );
            })}
          </ul>
        </div>
        </>
      ))
    }
  </div>
</nav>

<style>
  .sidebar {
    width: var(--sidebar-w);
    flex: 0 0 var(--sidebar-w);
    height: 100%;
  }
  .sidebar-scroll {
    position: sticky;
    top: var(--header-h);
    max-height: calc(100vh - var(--header-h));
    overflow-y: auto;
    padding: var(--space-8) var(--space-6) var(--space-12) 0;
    scrollbar-width: thin;
  }

  .nav-section + .nav-section {
    margin-top: var(--space-6);
  }

  /* Track switcher: identifies the current track (claude.ai vs Claude Code),
     links home, and offers a subtle jump to the other track. Sits above the
     section list, separated by a hairline rule. */
  .track-switcher {
    margin-bottom: var(--space-6);
    padding: 0 var(--space-3) var(--space-5);
    border-bottom: 1px solid var(--line);
  }
  .track-home {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-family: var(--font-mono);
    font-size: 0.66rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ink-muted);
    transition: color 0.15s ease;
  }
  .track-home:hover {
    color: var(--kpmg-blue);
    text-decoration: none;
  }
  .track-eyebrow {
    margin: var(--space-3) 0 0;
    font-family: var(--font-mono);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--kpmg-cobalt);
  }
  .track-name {
    margin: 2px 0 var(--space-3);
    font-size: 1.05rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--ink);
  }
  .track-switch {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.76rem;
    font-weight: 600;
    color: var(--kpmg-blue);
    transition: gap 0.15s ease;
  }
  .track-switch:hover {
    text-decoration: none;
    gap: 9px;
  }
  .nav-label {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-muted);
    margin: 0 0 var(--space-2);
    padding-left: var(--space-3);
  }
  .nav-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .nav-list li {
    margin: 0;
  }

  .nav-link {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 6px var(--space-3);
    border-radius: var(--radius-sm);
    color: var(--ink-muted);
    font-size: 0.92rem;
    line-height: 1.4;
    transition:
      color 0.15s ease,
      background 0.15s ease;
  }
  a.nav-link:hover {
    color: var(--ink);
    background: var(--bg-soft);
    text-decoration: none;
  }
  .nav-num {
    flex: 0 0 auto;
    min-width: 18px;
    font-family: var(--font-mono);
    font-size: 0.66rem;
    font-weight: 600;
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.02em;
    color: #b4bdc9;
    transition: color 0.15s ease;
  }
  .nav-link.active {
    color: var(--kpmg-blue);
    font-weight: 650;
    background: rgba(0, 51, 141, 0.05);
  }
  .nav-link.active .nav-num {
    color: var(--kpmg-blue);
  }
  a.nav-link:hover .nav-num {
    color: var(--ink-muted);
  }

  .nav-soon {
    color: #9aa6b6;
    cursor: default;
  }
  .nav-soon .nav-num {
    color: #ccd3dd;
  }
  .soon-tag {
    margin-left: auto;
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #aeb8c6;
    background: var(--bg-soft);
    border: 1px solid var(--line);
    border-radius: 4px;
    padding: 1px 5px;
  }

  @media (max-width: 1080px) {
    .sidebar {
      display: none;
    }
  }
</style>
