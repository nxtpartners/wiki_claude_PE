---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { withBase } from '../utils/withBase';

// Resolve link targets against real content so we never render a broken link.
// Mirrors the pattern used by Sidebar.astro and Footer.astro.
const docs = await getCollection('docs', ({ data }) => data.draft !== true);
const existing = new Set(docs.map((d) => d.id));

// Return the slug if a page exists, otherwise fall back to /welcome.
// Base-aware so every curriculum link resolves under the deploy base path.
const resolve = (slug: string) => withBase(existing.has(slug) ? `/${slug}` : '/welcome');

// The six-module curriculum, in deliberate order.
const curriculum = [
  {
    index: '01',
    name: 'Foundations',
    href: resolve('foundations/what-claude-is'),
    outcome: 'Understand what Claude can and cannot be trusted with.',
  },
  {
    index: '02',
    name: 'Context',
    href: resolve('context/why-context'),
    outcome: 'Brief Claude so it answers as if it has been on the deal for weeks.',
  },
  {
    index: '03',
    name: 'Projects',
    href: resolve('projects/what-projects-are'),
    outcome: 'Stand up a clean, confidential workspace for each deal or function.',
  },
  {
    index: '04',
    name: 'PE Playbooks',
    href: resolve('playbooks/cim-analysis'),
    outcome: 'Run CIMs, due diligence, IC memos, and model reviews step by step.',
  },
  {
    index: '05',
    name: 'Power Features',
    href: resolve('power-features/connectors'),
    outcome: 'Use connectors, data analysis, artifacts, and web search with judgment.',
  },
  {
    index: '06',
    name: 'Best Practices',
    href: resolve('best-practices/verify-everything'),
    outcome: 'Verify everything and keep confidential data where it belongs.',
  },
];

// The advanced track: six Claude Code modules, for hands-on work in your files.
const advancedTrack = [
  { index: '01', name: 'Getting Started', href: resolve('claude-code/what-it-is'), outcome: 'See what Claude Code is, then install VS Code and sign in the safe way.' },
  { index: '02', name: 'First Sessions', href: resolve('claude-code/first-session'), outcome: 'Open a folder, ask for something small, and approve your first change.' },
  { index: '03', name: 'Good Habits', href: resolve('claude-code/claude-md'), outcome: 'Set up CLAUDE.md, save with Git, ship safely, and keep the cheat sheet close.' },
  { index: '04', name: 'PE Recipes', href: resolve('claude-code/recipes-data'), outcome: 'Put it to work: data packs, model checks, and summarizing memos.' },
  { index: '05', name: 'Examples', href: resolve('claude-code/example-value-creation'), outcome: 'See a finished deliverable: a filterable AI value-creation matrix.' },
  { index: '06', name: 'Glossary', href: resolve('claude-code/glossary'), outcome: 'Look up any Claude Code term, in plain English.' },
];
---

<BaseLayout title="Home">
  <Header />

  <main id="main">
    <!-- ===================== HERO ===================== -->
    <section class="hero" aria-labelledby="hero-title">
      <div class="hero-rule" aria-hidden="true"></div>
      <div class="container hero-grid">
        <!-- Left: the pitch -->
        <div class="hero-copy">
          <p class="mono-eyebrow hero-eyebrow" data-hero="1">KPMG Private Equity · Internal enablement</p>
          <h1 id="hero-title" class="hero-title" data-hero="2">
            Use Claude with confidence on private equity work.
          </h1>
          <p class="hero-sub" data-hero="3">
            This guide takes KPMG private equity teams from the basics to confident daily use.
            Confidential by design, written for the work you do, with no prior AI experience assumed.
          </p>
          <div class="hero-actions" data-hero="4">
            <a href={withBase('/welcome')} class="btn btn-primary">Start Here</a>
            <a href={withBase('/first-15-minutes')} class="btn btn-secondary">First 15 Minutes</a>
          </div>
          <p class="hero-meta mono-meta" data-hero="5">
            For Claude Enterprise &amp; Team · Self-paced · No prior AI experience required
          </p>
        </div>

        <!-- Right: the signature element, a live deal conversation -->
        <div class="hero-demo" data-hero="6">
          <div class="chat" role="img"
            aria-label="Illustration of a Claude conversation analysing a confidential information memorandum.">
            <div class="chat-chrome">
              <span class="chat-dots" aria-hidden="true"><i></i><i></i><i></i></span>
              <span class="chat-url mono-meta">claude.ai</span>
              <span class="chat-tag mono-meta">live deal</span>
            </div>

            <div class="chat-body">
              <!-- User turn -->
              <div class="msg msg-user" data-chat="1">
                <span class="msg-who mono-meta">You</span>
                <div class="bubble bubble-user">
                  <span class="file-chip">
                    <svg viewBox="0 0 24 24" width="14" height="14" aria-hidden="true">
                      <path d="M6 2h8l4 4v16H6z" fill="none" stroke="currentColor" stroke-width="1.6" />
                      <path d="M14 2v4h4" fill="none" stroke="currentColor" stroke-width="1.6" />
                    </svg>
                    Project_Atlas_CIM.pdf
                  </span>
                  <p>Summarise this CIM for an initial screen: thesis, financials, and the three biggest risks.</p>
                </div>
              </div>

              <!-- Claude turn -->
              <div class="msg msg-claude" data-chat="2">
                <span class="msg-who mono-meta">Claude</span>
                <div class="bubble bubble-claude">
                  <dl class="answer">
                    <div class="answer-row">
                      <dt>Business</dt>
                      <dd>B2B field-service software for mid-market contractors, recurring SaaS revenue.</dd>
                    </div>
                    <div class="answer-row">
                      <dt>Financials</dt>
                      <dd>Roughly 60m revenue, mid-20s percent growth, gross margin in the low 70s.</dd>
                    </div>
                    <div class="answer-row">
                      <dt>Thesis</dt>
                      <dd>Consolidate a fragmented market, raise net retention, expand into adjacent trades.</dd>
                    </div>
                    <div class="answer-row">
                      <dt>Key risks</dt>
                      <dd>Customer concentration, founder dependence, and thin disclosure on churn.</dd>
                    </div>
                  </dl>
                  <p class="verify-chip">
                    <svg viewBox="0 0 24 24" width="13" height="13" aria-hidden="true">
                      <path d="M5 12l4 4 10-10" fill="none" stroke="currentColor" stroke-width="2" />
                    </svg>
                    Verify figures against the source
                  </p>
                </div>
              </div>
            </div>
          </div>
          <p class="demo-caption mono-meta" aria-hidden="true">Illustrative. Your data stays in your workspace.</p>
        </div>
      </div>
    </section>

    <!-- ===================== CHOOSE YOUR TRACK ===================== -->
    <section class="section container tracks-section" aria-labelledby="tracks-title">
      <div class="tracks-head" data-reveal>
        <p class="mono-eyebrow">Two tracks</p>
        <h2 id="tracks-title" class="block-title">Two ways to work. Pick your track.</h2>
        <p class="block-sub">
          Both lead to the same Claude. The Core Track covers claude.ai, the web app most people use every
          day. The Advanced Track covers Claude Code, for hands-on work in your own files. Each track is
          self-contained, with its own guide from first page to last, so you can follow one without the other.
        </p>
      </div>

      <div class="tracks">
        <!-- Core track: claude.ai -->
        <article class="track-panel track-core" data-reveal>
          <div class="panel-chrome chrome-web">
            <span class="chrome-dots" aria-hidden="true"><i></i><i></i><i></i></span>
            <span class="chrome-url mono-meta">claude.ai</span>
            <span class="chrome-tag chrome-tag-web mono-meta">browser</span>
          </div>
          <div class="panel-body">
            <p class="mono-eyebrow panel-eyebrow panel-eyebrow-core">Core Track · Start here</p>
            <h3 class="panel-title">claude.ai</h3>
            <p class="panel-sub">
              The chat app in your browser. Ask questions, analyze documents, and draft. This is where
              everyone starts, and no prior experience is needed.
            </p>
            <ol class="module-list">
              {
                curriculum.map((m) => (
                  <li class="module" data-reveal>
                    <a class="module-link" href={m.href}>
                      <span class="module-index" aria-hidden="true">{m.index}</span>
                      <span class="module-body">
                        <span class="module-name">{m.name}</span>
                        <span class="module-outcome">{m.outcome}</span>
                      </span>
                      <span class="module-go" aria-hidden="true">→</span>
                    </a>
                  </li>
                ))
              }
            </ol>
            <a href={withBase('/welcome')} class="btn btn-primary panel-cta">
              <span>Start the Core Track</span>
              <span class="cta-arrow" aria-hidden="true">→</span>
            </a>
          </div>
        </article>

        <!-- Advanced track: Claude Code -->
        <article class="track-panel track-advanced" data-reveal>
          <div class="panel-chrome chrome-terminal">
            <span class="chrome-dots" aria-hidden="true"><i></i><i></i><i></i></span>
            <span class="chrome-url mono-meta">claude-code</span>
            <span class="chrome-tag chrome-tag-term mono-meta">in your files</span>
          </div>
          <div class="panel-body">
            <p class="mono-eyebrow panel-eyebrow panel-eyebrow-adv">Advanced Track</p>
            <h3 class="panel-title">Claude Code</h3>
            <p class="panel-sub">
              Claude working directly in the files and folders on your computer, in the VS Code editor. For
              hands-on, file-heavy work, with your approval before every change.
            </p>
            <ol class="module-list">
              {
                advancedTrack.map((m) => (
                  <li class="module" data-reveal>
                    <a class="module-link" href={m.href}>
                      <span class="module-index" aria-hidden="true">{m.index}</span>
                      <span class="module-body">
                        <span class="module-name">{m.name}</span>
                        <span class="module-outcome">{m.outcome}</span>
                      </span>
                      <span class="module-go" aria-hidden="true">→</span>
                    </a>
                  </li>
                ))
              }
            </ol>
            <a href={withBase('/claude-code/welcome')} class="btn btn-ink panel-cta">
              <span>Enter the Advanced Track</span>
              <span class="cta-arrow" aria-hidden="true">→</span>
            </a>
          </div>
        </article>
      </div>
    </section>

    <!-- ===================== CONFIDENTIALITY BAND ===================== -->
    <section class="confidential" aria-labelledby="confidential-title" data-reveal>
      <div class="container confidential-grid">
        <p class="mono-eyebrow confidential-eyebrow">Confidential by design</p>
        <h2 id="confidential-title" class="confidential-statement">
          On Claude Enterprise &amp; Team, your prompts and uploads are not used to train models.
        </h2>
        <p class="confidential-sub">
          Throughout this guide we show exactly how to keep deal data private and handle NDAs the right way.
        </p>
        <a href={withBase('/foundations/what-claude-is')} class="confidential-link">How it works</a>
      </div>
    </section>

    <!-- ===================== CLOSING CTA ===================== -->
    <section class="section container closing" aria-labelledby="closing-title" data-reveal>
      <p class="mono-eyebrow closing-eyebrow">Begin</p>
      <h2 id="closing-title" class="closing-title">Start with a fifteen-minute win.</h2>
      <p class="closing-sub">
        Open Claude, bring one real document, and walk away with something useful. The rest of the guide builds from
        there.
      </p>
      <div class="closing-actions">
        <a href={withBase('/first-15-minutes')} class="btn btn-primary">First 15 Minutes</a>
        <a href={withBase('/welcome')} class="btn btn-secondary">Read the Welcome</a>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  /* ---------- Shared institutional accents ---------- */
  .mono-eyebrow {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--kpmg-cobalt);
    margin: 0 0 var(--space-4);
  }
  .mono-meta {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.06em;
    color: var(--ink-muted);
  }
  .block-title {
    margin: 0 0 var(--space-3);
    font-size: clamp(1.7rem, 1.35rem + 1.4vw, 2.4rem);
    letter-spacing: -0.025em;
  }
  .block-sub {
    margin: 0;
    font-size: 1.08rem;
    color: var(--ink-muted);
    line-height: 1.6;
    max-width: 58ch;
  }

  /* ---------- HERO ---------- */
  .hero {
    position: relative;
    background:
      radial-gradient(ellipse 60% 70% at 88% 0%, rgba(30, 73, 226, 0.06), transparent 60%),
      var(--bg);
    border-bottom: 1px solid var(--line);
    overflow: hidden;
  }
  .hero-rule {
    position: absolute;
    inset: 0;
    background-image: linear-gradient(to right, rgba(0, 51, 141, 0.035) 1px, transparent 1px);
    background-size: 96px 100%;
    pointer-events: none;
  }
  .hero-grid {
    position: relative;
    display: grid;
    grid-template-columns: 1.02fr 0.98fr;
    gap: var(--space-16);
    align-items: center;
    padding-top: var(--space-24);
    padding-bottom: var(--space-24);
  }
  .hero-copy {
    max-width: 36rem;
  }
  .hero-eyebrow {
    margin-bottom: var(--space-5);
  }
  .hero-title {
    margin: 0 0 var(--space-6);
    font-size: clamp(2.4rem, 1.6rem + 2.8vw, 3.7rem);
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: -0.038em;
    color: var(--ink);
  }
  .hero-sub {
    margin: 0 0 var(--space-8);
    font-size: clamp(1.05rem, 1rem + 0.35vw, 1.22rem);
    line-height: 1.62;
    color: var(--ink-muted);
    max-width: 40ch;
  }
  .hero-actions {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
  }
  .hero-meta {
    margin: var(--space-8) 0 0;
    padding-top: var(--space-4);
    border-top: 1px solid var(--line);
  }

  /* ---- Conversation card ---- */
  .hero-demo {
    position: relative;
  }
  .chat {
    background: #faf9f5;
    border: 1px solid #eae7dc;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg);
    overflow: hidden;
    transform: rotate(-0.4deg);
  }
  .chat-chrome {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-3) var(--space-4);
    background: #f0eee6;
    border-bottom: 1px solid #eae7dc;
  }
  .chat-dots {
    display: inline-flex;
    gap: 6px;
  }
  .chat-dots i {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: #d8d3c4;
  }
  .chat-url {
    margin-inline: auto;
    color: #8a8475;
  }
  .chat-tag {
    color: #be5d3a;
    background: #f4e8e1;
    border-radius: 999px;
    padding: 2px 9px;
    font-size: 0.62rem;
    letter-spacing: 0.1em;
  }
  .chat-body {
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    background: linear-gradient(180deg, #faf9f5 0%, #f5f4ee 100%);
  }
  .msg {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .msg-user {
    align-items: flex-end;
  }
  .msg-who {
    font-size: 0.62rem;
    letter-spacing: 0.12em;
  }
  .bubble {
    border-radius: var(--radius-md);
    padding: var(--space-4) var(--space-4);
    font-size: 0.9rem;
    line-height: 1.55;
    max-width: 92%;
  }
  .bubble p {
    margin: 0;
  }
  .bubble-user {
    background: #f0eee6;
    color: #3d3b36;
    border: 1px solid #e7e3d7;
    border-bottom-right-radius: 4px;
  }
  .bubble-claude {
    background: transparent;
    border: none;
    color: #3d3b36;
    box-shadow: none;
    padding: 0;
    border-bottom-left-radius: 4px;
    max-width: 100%;
  }
  .file-chip {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: #3d3b36;
    background: #ffffff;
    border: 1px solid #e0dccd;
    border-radius: var(--radius-sm);
    padding: 4px 8px;
    margin-bottom: var(--space-3);
  }
  .answer {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  .answer-row {
    display: grid;
    grid-template-columns: 84px 1fr;
    gap: var(--space-3);
    align-items: baseline;
  }
  .answer dt {
    margin: 0;
    font-weight: 700;
    font-size: 0.82rem;
    color: #2a2722;
  }
  .answer dd {
    margin: 0;
    font-size: 0.86rem;
    color: #3d3b36;
  }
  .verify-chip {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin: var(--space-4) 0 0;
    padding-top: var(--space-3);
    border-top: 1px dashed #e0dccd;
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.04em;
    color: #be5d3a;
  }
  .demo-caption {
    margin: var(--space-3) 0 0;
    text-align: right;
    font-size: 0.64rem;
  }

  /* ---------- Section rhythm ---------- */
  .section {
    padding-top: var(--space-24);
    padding-bottom: var(--space-12);
  }

  /* ---------- CHOOSE YOUR TRACK ---------- */
  .tracks-head {
    max-width: 62ch;
    margin-bottom: var(--space-12);
  }

  /* Two doorway panels side by side; each is a self-contained track with its
     own chrome (warm browser for claude.ai, dark terminal for Claude Code) so
     the two are visually and conceptually distinct. Stacks on narrow screens. */
  .tracks {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-8);
    align-items: stretch;
  }

  .track-panel {
    display: flex;
    flex-direction: column;
    min-width: 0;
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--bg);
    box-shadow: var(--shadow-sm);
    transition:
      border-color 0.2s ease,
      box-shadow 0.2s ease,
      transform 0.2s ease;
  }
  .track-panel:hover {
    box-shadow: var(--shadow-lg);
    transform: translateY(-3px);
  }
  .track-core:hover {
    border-color: var(--kpmg-cobalt);
  }
  .track-advanced:hover {
    border-color: var(--vs-accent);
  }

  /* ---- Panel chrome (the little window title bar) ---- */
  .panel-chrome {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-3) var(--space-4);
  }
  .chrome-web {
    background: #f0eee6;
    border-bottom: 1px solid #eae7dc;
  }
  .chrome-terminal {
    background: var(--vs-sidebar-bg);
    border-bottom: 1px solid var(--vs-border);
  }
  .chrome-dots {
    display: inline-flex;
    gap: 6px;
  }
  .chrome-dots i {
    width: 9px;
    height: 9px;
    border-radius: 50%;
  }
  .chrome-web .chrome-dots i {
    background: #d8d3c4;
  }
  .chrome-terminal .chrome-dots i {
    background: #3a4048;
  }
  .chrome-url {
    margin-inline: auto;
  }
  .chrome-web .chrome-url {
    color: #8a8475;
  }
  .chrome-terminal .chrome-url {
    color: var(--vs-muted);
  }
  .chrome-tag {
    border-radius: 999px;
    padding: 2px 9px;
    font-size: 0.62rem;
    letter-spacing: 0.1em;
  }
  .chrome-tag-web {
    color: #be5d3a;
    background: #f4e8e1;
  }
  .chrome-tag-term {
    color: var(--vs-accent);
    background: rgba(74, 158, 255, 0.14);
  }

  /* ---- Panel body ---- */
  .panel-body {
    display: flex;
    flex-direction: column;
    flex: 1;
    padding: var(--space-8) var(--space-7) var(--space-7);
  }
  .panel-eyebrow {
    margin: 0 0 var(--space-3);
  }
  .panel-eyebrow-adv {
    color: var(--kpmg-blue);
  }
  .panel-title {
    margin: 0 0 var(--space-2);
    font-size: 1.6rem;
    font-weight: 800;
    letter-spacing: -0.03em;
    color: var(--ink);
  }
  .panel-sub {
    margin: 0 0 var(--space-6);
    font-size: 0.98rem;
    color: var(--ink-muted);
    line-height: 1.55;
  }

  /* ---- Module list within a panel ---- */
  .module-list {
    list-style: none;
    margin: 0 0 var(--space-7);
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
    border-top: 1px solid var(--line);
  }
  .module {
    margin: 0;
    border-bottom: 1px solid var(--line);
  }
  .module-link {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: var(--space-4);
    align-items: center;
    padding: var(--space-4) var(--space-2);
    color: inherit;
    transition: padding-left 0.18s ease;
  }
  .module-link:hover {
    text-decoration: none;
    padding-left: var(--space-4);
  }
  .module-index {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    font-weight: 500;
    line-height: 1;
    letter-spacing: 0.04em;
    color: var(--kpmg-cobalt);
    font-variant-numeric: tabular-nums;
  }
  .track-advanced .module-index {
    color: var(--kpmg-blue);
  }
  .module-body {
    display: flex;
    flex-direction: column;
    gap: 3px;
    min-width: 0;
  }
  .module-name {
    font-size: 1.02rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    color: var(--ink);
  }
  .module-outcome {
    font-size: 0.88rem;
    color: var(--ink-muted);
    line-height: 1.45;
  }
  .module-go {
    opacity: 0;
    transform: translateX(-4px);
    transition:
      opacity 0.18s ease,
      transform 0.18s ease;
    color: var(--kpmg-cobalt);
    font-size: 1.1rem;
  }
  .module-link:hover .module-go {
    opacity: 1;
    transform: none;
  }

  /* ---- Panel call to action, pinned to the bottom ---- */
  .panel-cta {
    margin-top: auto;
    align-self: stretch;
    justify-content: space-between;
    gap: var(--space-4);
    font-size: 0.92rem;
    padding: 0.72em 1.1em;
  }
  .cta-arrow {
    font-size: 1.05rem;
    line-height: 1;
    transition: transform 0.18s ease;
  }
  .panel-cta:hover .cta-arrow {
    transform: translateX(3px);
  }
  .btn-ink {
    background: var(--ink);
    color: #fff;
