---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { withBase } from '../utils/withBase';
import twoPaths from '../assets/diagrams/home-two-paths.png';

// Resolve link targets against real content so we never render a broken link.
// Mirrors the pattern used by Sidebar.astro and Footer.astro.
const docs = await getCollection('docs', ({ data }) => data.draft !== true);
const existing = new Set(docs.map((d) => d.id));

// Return the slug if a page exists, otherwise fall back to /welcome.
// Base-aware so every curriculum link resolves under the deploy base path.
const resolve = (slug: string) => withBase(existing.has(slug) ? `/${slug}` : '/welcome');

// The six-module curriculum, in deliberate order.
const curriculum = [
  {
    index: '01',
    name: 'Foundations',
    href: resolve('foundations/what-claude-is'),
    outcome: 'Understand what Claude can and cannot be trusted with.',
  },
  {
    index: '02',
    name: 'Context',
    href: resolve('context/why-context'),
    outcome: 'Brief Claude so it answers as if it has been on the deal for weeks.',
  },
  {
    index: '03',
    name: 'Projects',
    href: resolve('projects/what-projects-are'),
    outcome: 'Stand up a clean, confidential workspace for each deal or function.',
  },
  {
    index: '04',
    name: 'PE Playbooks',
    href: resolve('playbooks/cim-analysis'),
    outcome: 'Run CIMs, due diligence, IC memos, and model reviews step by step.',
  },
  {
    index: '05',
    name: 'Power Features',
    href: resolve('power-features/connectors'),
    outcome: 'Use connectors, data analysis, artifacts, and web search with judgment.',
  },
  {
    index: '06',
    name: 'Best Practices',
    href: resolve('best-practices/verify-everything'),
    outcome: 'Verify everything and keep confidential data where it belongs.',
  },
];

// The advanced track: six Claude Code modules, for hands-on work in your files.
const advancedTrack = [
  { index: '01', name: 'Getting Started', href: resolve('claude-code/what-it-is'), outcome: 'See what Claude Code is, then install VS Code and sign in the safe way.' },
  { index: '02', name: 'First Sessions', href: resolve('claude-code/first-session'), outcome: 'Open a folder, ask for something small, and approve your first change.' },
  { index: '03', name: 'Good Habits', href: resolve('claude-code/claude-md'), outcome: 'Set up CLAUDE.md, save with Git, ship safely, and keep the cheat sheet close.' },
  { index: '04', name: 'PE Recipes', href: resolve('claude-code/recipes-data'), outcome: 'Put it to work: data packs, model checks, and summarizing memos.' },
  { index: '05', name: 'Examples', href: resolve('claude-code/example-value-creation'), outcome: 'See a finished deliverable: a filterable AI value-creation matrix.' },
  { index: '06', name: 'Glossary', href: resolve('claude-code/glossary'), outcome: 'Look up any Claude Code term, in plain English.' },
];
---

<BaseLayout title="Home">
  <Header />

  <main id="main">
    <!-- ===================== HERO ===================== -->
    <section class="hero" aria-labelledby="hero-title">
      <div class="hero-rule" aria-hidden="true"></div>
      <div class="container hero-grid">
        <!-- Left: the pitch -->
        <div class="hero-copy">
          <h1 id="hero-title" class="hero-title" data-hero="2">
            Claude for Private Equity
          </h1>
          <p class="hero-sub" data-hero="3">
            One Claude, two ways to work: claude.ai for everyday questions, and Claude Code for advanced, hands-on work in your files.
          </p>
          <div class="hero-actions" data-hero="4">
            <a href={withBase('/welcome')} class="btn btn-primary">Start with claude.ai</a>
            <a href={withBase('/claude-code/welcome')} class="btn btn-secondary">Explore Claude Code</a>
          </div>
          <p class="hero-meta mono-meta" data-hero="5">
            For Claude Enterprise &amp; Team · Self-paced · No prior AI experience required
          </p>
        </div>

        <!-- Right: the signature element, a diagram of the two ways to work -->
        <div class="hero-demo" data-hero="6">
          <Image
            src={twoPaths}
            alt="One Claude, two ways to work. Your private equity work flows into two paths: claude.ai in the browser for questions, analysis, and drafting, and Claude Code in your files for hands-on work. Both reach a confident, verified result that stays confidential by design."
            class="hero-diagram"
            loading="eager"
          />
        </div>
      </div>
    </section>

    <!-- ===================== CONFIDENTIALITY BAND ===================== -->
    <section class="confidential" aria-labelledby="confidential-title" data-reveal>
      <div class="container confidential-grid">
        <p class="mono-eyebrow confidential-eyebrow">Confidential by design</p>
        <h2 id="confidential-title" class="confidential-statement">
          On Claude Enterprise &amp; Team, your prompts and uploads are not used to train models.
        </h2>
        <p class="confidential-sub">
          In claude.ai or Claude Code, your deal data stays private and NDAs are handled the right way.
        </p>
      </div>
    </section>

    <!-- ===================== CHOOSE YOUR TRACK ===================== -->
    <section class="section container tracks-section" aria-labelledby="tracks-title">
      <div class="tracks-head" data-reveal>
        <h2 id="tracks-title" class="block-title">Two ways to work. Pick your track.</h2>
      </div>

      <div class="tracks">
        <!-- Core track: claude.ai -->
        <div class="track-col" data-reveal>
          <p class="mono-eyebrow track-label track-label-core">Core Track · Start here</p>
          <article class="track-panel track-core">
            <div class="panel-chrome chrome-web">
              <span class="chrome-dots" aria-hidden="true"><i></i><i></i><i></i></span>
              <span class="chrome-url mono-meta">claude.ai</span>
              <span class="chrome-tag chrome-tag-web mono-meta">browser</span>
            </div>
            <div class="panel-body">
              <h3 class="panel-title">claude.ai</h3>
              <p class="panel-sub">
                The chat app in your browser. Ask questions, analyze documents, and draft. This is where
                everyone starts, and no prior experience is needed.
              </p>
              <ol class="module-list">
                {
                  curriculum.map((m) => (
                    <li class="module" data-reveal>
                      <a class="module-link" href={m.href}>
                        <span class="module-index" aria-hidden="true">{m.index}</span>
                        <span class="module-body">
                          <span class="module-name">{m.name}</span>
                          <span class="module-outcome">{m.outcome}</span>
                        </span>
                        <span class="module-go" aria-hidden="true">→</span>
                      </a>
                    </li>
                  ))
                }
              </ol>
              <a href={withBase('/welcome')} class="btn btn-primary panel-cta">
                <span>Start the Core Track</span>
                <span class="cta-arrow" aria-hidden="true">→</span>
              </a>
            </div>
          </article>
        </div>

        <!-- Advanced track: Claude Code -->
        <div class="track-col" data-reveal>
          <p class="mono-eyebrow track-label track-label-adv">Advanced Track</p>
          <article class="track-panel track-advanced">
            <div class="panel-chrome chrome-terminal">
              <span class="chrome-dots" aria-hidden="true"><i></i><i></i><i></i></span>
              <span class="chrome-url mono-meta">claude-code</span>
              <span class="chrome-tag chrome-tag-term mono-meta">in your files</span>
            </div>
            <div class="panel-body">
              <h3 class="panel-title">Claude Code</h3>
              <p class="panel-sub">
                Claude working directly in the files and folders on your computer, in the VS Code editor. For
                hands-on, file-heavy work, with your approval before every change.
              </p>
              <ol class="module-list">
                {
                  advancedTrack.map((m) => (
                    <li class="module" data-reveal>
                      <a class="module-link" href={m.href}>
                        <span class="module-index" aria-hidden="true">{m.index}</span>
                        <span class="module-body">
                          <span class="module-name">{m.name}</span>
                          <span class="module-outcome">{m.outcome}</span>
                        </span>
                        <span class="module-go" aria-hidden="true">→</span>
                      </a>
                    </li>
                  ))
                }
              </ol>
              <a href={withBase('/claude-code/welcome')} class="btn btn-ink panel-cta">
                <span>Enter the Advanced Track</span>
                <span class="cta-arrow" aria-hidden="true">→</span>
              </a>
            </div>
          </article>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  /* ---------- Shared institutional accents ---------- */
  .mono-eyebrow {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--kpmg-cobalt);
    margin: 0 0 var(--space-4);
  }
  .mono-meta {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.06em;
    color: var(--ink-muted);
  }
  .block-title {
    margin: 0 0 var(--space-3);
    font-size: clamp(1.7rem, 1.35rem + 1.4vw, 2.4rem);
    letter-spacing: -0.025em;
  }
  .block-sub {
    margin: 0;
    font-size: 1.08rem;
    color: var(--ink-muted);
    line-height: 1.6;
    max-width: 58ch;
  }

  /* ---------- HERO ---------- */
  .hero {
    position: relative;
    min-height: calc(100svh - var(--header-h));
    display: flex;
    align-items: center;
    background:
      radial-gradient(ellipse 60% 70% at 88% 0%, rgba(30, 73, 226, 0.06), transparent 60%),
      var(--bg);
    border-bottom: 1px solid var(--line);
    overflow: hidden;
  }
  .hero-rule {
    position: absolute;
    inset: 0;
    background-image: linear-gradient(to right, rgba(0, 51, 141, 0.035) 1px, transparent 1px);
    background-size: 96px 100%;
    pointer-events: none;
  }
  .hero-grid {
    position: relative;
    width: 100%;
    display: grid;
    grid-template-columns: 0.85fr 1.15fr;
    gap: var(--space-12);
    align-items: center;
    padding-top: var(--space-24);
    padding-bottom: var(--space-24);
  }
  .hero-copy {
    max-width: 36rem;
  }
  .hero-title {
    margin: 0 0 var(--space-6);
    font-size: clamp(2.4rem, 1.6rem + 2.8vw, 3.7rem);
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: -0.038em;
    color: var(--ink);
  }
  .hero-sub {
    margin: 0 0 var(--space-8);
    font-size: clamp(1.05rem, 1rem + 0.35vw, 1.22rem);
    line-height: 1.62;
    color: var(--ink-muted);
    max-width: 40ch;
  }
  .hero-actions {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
  }
  .hero-meta {
    margin: var(--space-8) 0 0;
    padding-top: var(--space-4);
    border-top: 1px solid var(--line);
  }

  /* ---- Signature diagram card ---- */
  .hero-demo {
    position: relative;
  }
  .hero-diagram {
    display: block;
    width: 100%;
    height: auto;
    border-radius: var(--radius-lg);
    border: 1px solid var(--line);
    box-shadow: var(--shadow-md);
    background: var(--bg);
  }

  /* ---------- Section rhythm ---------- */
  .section {
    padding-top: var(--space-24);
    padding-bottom: var(--space-12);
  }

  /* ---------- CHOOSE YOUR TRACK ---------- */
  .tracks-head {
    max-width: 62ch;
    margin-bottom: var(--space-12);
  }

  /* Two doorway panels side by side; each is a self-contained track with its
     own chrome (warm browser for claude.ai, dark terminal for Claude Code) so
     the two are visually and conceptually distinct. Stacks on narrow screens. */
  .tracks {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-8);
    align-items: stretch;
  }

  .track-col {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }
  .track-col > .track-panel {
    flex: 1;
  }
  .track-label {
    margin: 0 0 var(--space-3);
  }
  .track-label-adv {
    color: var(--kpmg-blue);
  }

  .track-panel {
    display: flex;
    flex-direction: column;
    min-width: 0;
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--bg);
    box-shadow: var(--shadow-sm);
    transition:
      border-color 0.2s ease,
      box-shadow 0.2s ease,
      transform 0.2s ease;
  }
  .track-panel:hover {
    box-shadow: var(--shadow-lg);
    transform: translateY(-3px);
  }
  .track-core:hover {
    border-color: var(--kpmg-cobalt);
  }
  .track-advanced:hover {
    border-color: var(--vs-accent);
  }

  /* ---- Panel chrome (the little window title bar) ---- */
  .panel-chrome {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-3) var(--space-4);
  }
  .chrome-web {
    background: #f0eee6;
    border-bottom: 1px solid #eae7dc;
  }
  .chrome-terminal {
    background: var(--vs-sidebar-bg);
    border-bottom: 1px solid var(--vs-border);
  }
  .chrome-dots {
    display: inline-flex;
    gap: 6px;
  }
  .chrome-dots i {
    width: 9px;
    height: 9px;
    border-radius: 50%;
  }
  .chrome-web .chrome-dots i {
    background: #d8d3c4;
  }
  .chrome-terminal .chrome-dots i {
    background: #3a4048;
  }
  .chrome-url {
    margin-inline: auto;
  }
  .chrome-web .chrome-url {
    color: #8a8475;
  }
  .chrome-terminal .chrome-url {
    color: var(--vs-muted);
  }
  .chrome-tag {
    border-radius: 999px;
    padding: 2px 9px;
    font-size: 0.62rem;
    letter-spacing: 0.1em;
  }
  .chrome-tag-web {
    color: #be5d3a;
    background: #f4e8e1;
  }
  .chrome-tag-term {
    color: var(--vs-accent);
    background: rgba(74, 158, 255, 0.14);
  }

  /* ---- Panel body ---- */
  .panel-body {
    display: flex;
    flex-direction: column;
    flex: 1;
    padding: var(--space-8);
  }
  .panel-title {
    margin: 0 0 var(--space-2);
    font-size: 1.6rem;
    font-weight: 800;
    letter-spacing: -0.03em;
    color: var(--ink);
  }
  .panel-sub {
    margin: 0 0 var(--space-6);
    font-size: 0.98rem;
    color: var(--ink-muted);
    line-height: 1.55;
  }

  /* ---- Module list within a panel ---- */
  .module-list {
    list-style: none;
    margin: 0 0 var(--space-6);
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
    border-top: 1px solid var(--line);
  }
  .module {
    margin: 0;
    border-bottom: 1px solid var(--line);
  }
  .module-link {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: var(--space-4);
    align-items: center;
    padding: var(--space-4) var(--space-2);
    color: inherit;
    transition: padding-left 0.18s ease;
  }
  .module-link:hover {
    text-decoration: none;
    padding-left: var(--space-4);
  }
  .module-index {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    font-weight: 500;
    line-height: 1;
    letter-spacing: 0.04em;
    color: var(--kpmg-cobalt);
    font-variant-numeric: tabular-nums;
  }
  .track-advanced .module-index {
    color: var(--kpmg-blue);
  }
  .module-body {
    display: flex;
    flex-direction: column;
    gap: 3px;
    min-width: 0;
  }
  .module-name {
    font-size: 1.02rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    color: var(--ink);
  }
  .module-outcome {
    font-size: 0.88rem;
    color: var(--ink-muted);
    line-height: 1.45;
  }
  .module-go {
    opacity: 0;
    transform: translateX(-4px);
    transition:
      opacity 0.18s ease,
      transform 0.18s ease;
    color: var(--kpmg-cobalt);
    font-size: 1.1rem;
  }
  .module-link:hover .module-go {
    opacity: 1;
    transform: none;
  }

  /* ---- Panel call to action, pinned to the bottom ---- */
  .panel-cta {
    margin-top: auto;
    align-self: stretch;
    justify-content: space-between;
    gap: var(--space-4);
    font-size: 0.92rem;
    padding: 0.72em 1.1em;
  }
  .cta-arrow {
    font-size: 1.05rem;
    line-height: 1;
    transition: transform 0.18s ease;
  }
  .panel-cta:hover .cta-arrow {
    transform: translateX(3px);
  }
  .btn-ink {
    background: var(--ink);
    color: #fff;
    border: 1px solid var(--ink);
  }
  .btn-ink:hover {
    text-decoration: none;
    background: #000;
    border-color: #000;
  }

  /* ---------- CONFIDENTIALITY BAND ---------- */
  .confidential {
    margin: var(--space-24) 0;
    background:
      radial-gradient(ellipse 50% 120% at 100% 50%, rgba(172, 234, 255, 0.14), transparent 60%),
      linear-gradient(135deg, #001f57 0%, var(--kpmg-blue) 70%);
    color: #fff;
    border-top: 3px solid var(--kpmg-sky);
  }
  .confidential-grid {
    display: grid;
    grid-template-areas:
      'eyebrow'
      'statement'
      'sub';
    gap: var(--space-3);
    padding-top: var(--space-16);
    padding-bottom: var(--space-16);
  }
  .confidential-eyebrow {
    grid-area: eyebrow;
    color: var(--kpmg-sky);
    margin: 0;
  }
  .confidential-statement {
    grid-area: statement;
    margin: 0;
    font-size: clamp(1.5rem, 1.2rem + 1.4vw, 2.2rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.18;
    color: #fff;
    max-width: 24ch;
  }
  .confidential-sub {
    grid-area: sub;
    margin: 0;
    color: rgba(255, 255, 255, 0.78);
    font-size: 1rem;
    line-height: 1.6;
    max-width: 50ch;
  }

  /* ---------- Responsive ---------- */
  @media (max-width: 960px) {
    .hero {
      min-height: 0;
      display: block;
    }
    .hero-grid {
      grid-template-columns: 1fr;
      gap: var(--space-12);
      padding-top: var(--space-16);
      padding-bottom: var(--space-16);
    }
    .hero-copy {
      max-width: none;
    }
  }

  /* Stack the two doorway panels (core then advanced) once side-by-side
     columns get too tight. */
  @media (max-width: 900px) {
    .tracks {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }
  }

  @media (max-width: 640px) {
    .panel-body {
      padding: var(--space-6);
    }
    .module-link {
      gap: var(--space-3);
    }
    .confidential-grid {
      gap: var(--space-4);
      align-items: start;
    }
  }
</style>

<script>
  import '../scripts/motion.ts';

  // Scoped, restrained build-in for the conversation card. Respects reduced motion.
  // The global motion system handles [data-hero] and [data-reveal]; this adds the
  // chat bubbles staggering in after the hero settles.
  (() => {
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const bubbles = Array.from(document.querySelectorAll<HTMLElement>('[data-chat]'));
    if (!bubbles.length) return;

    if (reduce) {
      bubbles.forEach((el) => {
        el.style.opacity = '1';
        el.style.transform = 'none';
      });
      return;
    }

    bubbles
      .sort((a, b) => Number(a.dataset.chat) - Number(b.dataset.chat))
      .forEach((el, i) => {
        el.style.opacity = '0';
        el.style.transform = 'translateY(14px)';
        el.style.transition = 'opacity 0.55s ease, transform 0.55s ease';
        window.setTimeout(() => {
          el.style.opacity = '1';
          el.style.transform = 'none';
        }, 620 + i * 220);
      });
  })();
</script>
