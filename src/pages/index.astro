<script>
  import '../scripts/motion.ts';

  // Scoped, restrained build-in for the conversation card. Respects reduced motion.
  // The global motion system handles [data-hero] and [data-reveal]; this adds the
  // chat bubbles staggering in after the hero settles.
  (() => {
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const bubbles = Array.from(document.querySelectorAll<HTMLElement>('[data-chat]'));
    if (!bubbles.length) return;

    if (reduce) {
      bubbles.forEach((el) => {
        el.style.opacity = '1';
        el.style.transform = 'none';
      });
      return;
    }

    bubbles
      .sort((a, b) => Number(a.dataset.chat) - Number(b.dataset.chat))
      .forEach((el, i) => {
        el.style.opacity = '0';
        el.style.transform = 'translateY(14px)';
        el.style.transition = 'opacity 0.55s ease, transform 0.55s ease';
        window.setTimeout(() => {
          el.style.opacity = '1';
          el.style.transform = 'none';
        }, 620 + i * 220);
      });
  })();
</script>
