---
import type { MarkdownHeading } from 'astro';
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Sidebar from '../components/Sidebar.astro';
import TableOfContents from '../components/TableOfContents.astro';
import PrevNext from '../components/PrevNext.astro';
import Footer from '../components/Footer.astro';
import { flatNav } from '../config/nav';

interface Props {
  title: string;
  description?: string;
  section: string;
  slug: string;
  headings: MarkdownHeading[];
}
const { title, description, section, slug, headings } = Astro.props;

// Position within the wiki for the breadcrumb-style label.
const flatIndex = flatNav.findIndex((n) => n.slug === slug);
const position = flatIndex >= 0 ? flatIndex + 1 : null;
---

<BaseLayout title={title} description={description}>
  <Header />

  <div class="doc-shell">
    <!-- Mobile sidebar toggle -->
    <button type="button" class="mobile-nav-toggle" id="mobile-nav-toggle" aria-expanded="false" aria-controls="mobile-sidebar">
      <svg viewBox="0 0 24 24" width="18" height="18" fill="none" aria-hidden="true">
        <path d="M4 7h16M4 12h16M4 17h16" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
      </svg>
      <span>{section}</span>
    </button>

    <div class="doc-grid container">
      <div class="doc-sidebar" id="mobile-sidebar">
        <Sidebar currentSlug={slug} />
      </div>

      <main class="doc-main" id="main">
        <article class="doc-article" data-pagefind-body>
          <header class="doc-header" data-reveal>
            <p class="doc-eyebrow">
              {section}{position ? <span class="doc-pos"> · {position} of {flatNav.length}</span> : null}
            </p>
            <h1 data-pagefind-meta="title">{title}</h1>
            {description && <p class="doc-lede">{description}</p>}
          </header>

          <div class="prose">
            <slot />
          </div>

          <PrevNext currentSlug={slug} />
        </article>
      </main>

      <aside class="doc-toc">
        <TableOfContents headings={headings} />
      </aside>
    </div>
  </div>

  <Footer />
</BaseLayout>

<style>
  .doc-shell {
    position: relative;
  }
  .doc-grid {
    display: flex;
    align-items: flex-start;
    gap: var(--space-12);
  }
  .doc-sidebar {
    flex: 0 0 var(--sidebar-w);
    align-self: stretch;
  }
  .doc-main {
    flex: 1 1 auto;
    min-width: 0;
    padding-top: var(--space-12);
    padding-bottom: var(--space-16);
  }
  .doc-article {
    max-width: var(--measure);
  }
  .doc-toc {
    flex: 0 0 var(--toc-w);
    padding-top: var(--space-4);
    align-self: stretch;
  }

  .doc-header {
    margin-bottom: var(--space-8);
    padding-bottom: var(--space-6);
    border-bottom: 1px solid var(--line);
  }
  .doc-eyebrow {
    margin: 0 0 var(--space-3);
    font-size: 0.78rem;
    font-weight: 650;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--kpmg-cobalt);
  }
  .doc-pos {
    color: var(--ink-muted);
    font-weight: 500;
    letter-spacing: 0.04em;
  }
  .doc-lede {
    margin: var(--space-4) 0 0;
    font-size: 1.18rem;
    line-height: 1.6;
    color: var(--ink-muted);
  }

  /* Prose rhythm */
  .prose :global(h2) {
    scroll-margin-top: calc(var(--header-h) + 16px);
  }
  .prose :global(h3) {
    scroll-margin-top: calc(var(--header-h) + 16px);
  }
  .prose :global(:first-child) {
    margin-top: 0;
  }

  /* Mobile sidebar */
  .mobile-nav-toggle {
    display: none;
    align-items: center;
    gap: 8px;
    margin: var(--space-4) var(--space-4) 0;
    padding: 9px 14px;
    font-family: var(--font-sans);
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--ink);
    background: var(--bg-soft);
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    cursor: pointer;
  }

  .doc-footer {
    border-top: 1px solid var(--line);
    background: var(--bg-soft);
    padding: var(--space-8) 0;
  }
  .doc-footer-inner {
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--space-3);
    font-size: 0.88rem;
    color: var(--ink-muted);
  }
  .doc-footer-inner strong {
    color: var(--ink);
  }

  @media (max-width: 1080px) {
    .doc-grid {
      gap: var(--space-8);
    }
    .mobile-nav-toggle {
      display: inline-flex;
    }
    .doc-sidebar {
      display: none;
      flex-basis: auto;
      width: 100%;
    }
    .doc-sidebar.open {
      display: block;
      padding-inline: var(--space-4);
    }
    .doc-sidebar.open :global(.sidebar) {
      width: 100%;
      flex-basis: auto;
    }
    .doc-sidebar.open :global(.sidebar-scroll) {
      position: static;
      max-height: none;
      padding-right: 0;
    }
    .doc-main {
      padding-top: var(--space-6);
    }
  }
</style>

<script>
  // Mobile sidebar toggle
  const toggle = document.getElementById('mobile-nav-toggle');
  const sidebar = document.getElementById('mobile-sidebar');
  toggle?.addEventListener('click', () => {
    const open = sidebar?.classList.toggle('open');
    toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
  });
</script>

<script>
  import '../scripts/motion.ts';
</script>
